# Repository allowlist
# Ignore every file by default while keeping directories traversable.
*
!*/

# Root project files
!/.gitignore
!/Cargo.lock
!/Cargo.toml
!/README.md
!/SECURITY.md
!/build.rs
!/config.toml.example
!/rust-toolchain.toml

# Checked-in build tools
!/protoc-33.4-win64.zip

# Owned repository trees
!/.github/**/*.yml
!/.github/**/*.yaml
!/PRD/**/*.md
!/examples/*.rs
!/proto/*.proto
!/scripts/*.ps1
!/src/**/*.rs
!/frontend/index.html
!/frontend/package.json
!/frontend/package-lock.json
!/frontend/tsconfig.json
!/frontend/src/**/*.ts
!/frontend/src/**/*.css
!/tools/protoc/readme.txt

# Security and machine-local deny rules always win.
/config.toml
**/.env
**/.env.*
**/credentials.json
**/*credentials*.json
**/*.pem
**/*.key
**/*.pfx
**/*.p12
**/config.local.toml
**/config.*.local.toml

# Generated output, diagnostics, and local backups
**/target/**
**/dist/**
**/logs/**
**/*.log
**/*.dmp
**/*.stackdump
**/*.bak
**/*.bak-*
**/*.orig
**/*~
**/*.exe
**/*.dll
**/*.pdb

# Editor and operating-system metadata
**/.idea/**
**/.vscode/**
**/*.swp
**/*.swo
**/.DS_Store
**/Thumbs.db
