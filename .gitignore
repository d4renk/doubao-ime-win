# Repository allowlist
# Ignore every file by default while keeping directories traversable.
*
!*/

# Root project files
!/.gitignore
!/Cargo.lock
!/Cargo.toml
!/README.md
!/SECURITY.md
!/build.rs
!/config.toml
!/config.toml.example
!/rust-toolchain.toml

# Checked-in source assets and maintenance tools
!/Gemini_Generated_Image_nse4abnse4abnse4.png
!/crop_icons.py
!/make_circular.py
!/process_icons.py
!/resize_icons.py
!/split_icons.py
!/protoc-33.4-win64.zip

# Owned repository trees
!/.github/**/*.yml
!/.github/**/*.yaml
!/PRD/**/*.md
!/assets/*.png
!/examples/*.rs
!/proto/*.proto
!/scripts/*.ps1
!/src/**/*.rs
!/frontend/index.html
!/frontend/package.json
!/frontend/package-lock.json
!/frontend/tsconfig.json
!/frontend/src/**/*.ts
!/frontend/src/**/*.css
!/tools/protoc/include/**/*.proto
!/tools/protoc/readme.txt

# Security and machine-local deny rules always win.
**/.env
**/.env.*
**/credentials.json
**/*credentials*.json
**/*.pem
**/*.key
**/*.pfx
**/*.p12
**/config.local.toml
**/config.*.local.toml

# Generated output, diagnostics, and local backups
**/target/**
**/dist/**
**/logs/**
**/*.log
**/*.dmp
**/*.stackdump
**/*.bak
**/*.bak-*
**/*.orig
**/*~
**/*.exe
**/*.dll
**/*.pdb

# Editor and operating-system metadata
**/.idea/**
**/.vscode/**
**/*.swp
**/*.swo
**/.DS_Store
**/Thumbs.db
